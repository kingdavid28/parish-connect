Options -MultiViews
RewriteEngine On
RewriteBase /parish-connect/

# Don't rewrite requests to the api/ folder — let PHP handle them
RewriteCond %{REQUEST_URI} ^/parish-connect/api/ [NC]
RewriteRule ^ - [L]

# Don't rewrite actual files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Send everything else to React app
RewriteRule ^ index.html [QSA,L]
