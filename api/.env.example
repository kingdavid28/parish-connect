DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=u222318185_youruser
DB_PASSWORD=your_db_password
DB_NAME=u222318185_parish_connect

; Generate with: php -r "echo bin2hex(random_bytes(64));"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_SECONDS=604800

; Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

; Web Push / VAPID keys — generate once with:
;   php vendor/bin/generate-vapid-keys
; or online: https://vapidkeys.com
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@yourparish.com

; GCash parish info — shown to users when they top up GBless
; Upload your GCash QR image to /api/uploads/ and set the URL below
GCASH_NUMBER=09XXXXXXXXX
GCASH_NAME=Parish Name Here
GCASH_QR_URL=https://your-domain.com/parish-connect/api/uploads/gcash-qr.png

; Sacraments (SVF parish) read-only database — separate from main DB
SAC_DB_HOST=localhost
SAC_DB_NAME=u222318185_svf_parish
SAC_DB_USER=u222318185_svf_user
SAC_DB_PASSWORD=your_sac_db_password

; Email (SMTP) — for notifications
; Use Hostinger's built-in SMTP or a service like Brevo/Mailgun
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourparish.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS=noreply@yourparish.com
MAIL_FROM_NAME=Parish Connect

; Auto-Post Cron — Groq AI (free tier)
; Get your free API key at: https://console.groq.com
; Leave empty to use built-in fallback templates instead
GROQ_API_KEY=
